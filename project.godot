; Engine configuration file.
; https://docs.godotengine.org/en/stable/tutorials/best_practices/project_organization.html

config_version=5

[application]

config/name="Fussball-Manager"
config/run/main_scene="res://scenes/StartScreen.tscn"
config/features=PackedStringArray("4.3", "C#")

[autoload]

GameState="res://scenes/autoload/GameState.tscn"

[display]

window/size/viewport_width=1400
window/size/viewport_height=900
window/size/resizable=true
window/size/min_width=1024
window/size/min_height=700

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
